# ════════════════════════════════════════════════════════════════════
#  Architecture hybride : frontend statique (GitHub Pages) + backend (Render)
# ════════════════════════════════════════════════════════════════════

# ─── Frontend (build statique GitHub Pages) ──────────────────
# URL absolue du backend Render appelée par le navigateur (agenda + formulaires).
# Inlinée au build (NEXT_PUBLIC_*). En local, pointez sur votre serveur Node.
NEXT_PUBLIC_API_BASE=http://localhost:3000
# Défini uniquement par le workflow GitHub Pages : sous-chemin du site.
# NEXT_PUBLIC_BASE_PATH=/terra_website
# Défini uniquement par le workflow GitHub Pages : active l'export statique.
# STATIC_EXPORT=true

# ─── Backend (Render) — secrets serveur ──────────────────────
# Wimi : générez un App Token dans Wimi → Paramètres → Mon compte → API
WIMI_APP_TOKEN=votre_app_token_ici
# ID de l'espace Wimi contenant l'agenda "Événements publics" (URL Wimi : /space/XXXXX/...)
WIMI_SPACE_ID=12345

# Resend (envoi des formulaires) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
# Expéditeur sur domaine vérifié dans Resend
CONTACT_FROM_EMAIL=Terra Numerica <site@terra-numerica.org>
# Destinataire des soumissions de formulaire
CONTACT_TO_EMAIL=contact@terra-numerica.org

# Origine exacte du frontend autorisée par CORS (sans chemin), ex. https://user.github.io
FRONTEND_ORIGIN=http://localhost:3001
